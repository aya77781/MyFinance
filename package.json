{
  "name": "finance-app",
  "version": "1.0.0",
  "description": "App de finances personnelles (backend Express + stockage fichiers JSON, mobile Expo)",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm install && npm --prefix backend install && npm --prefix mobile install",
    "reset": "npm --prefix backend run reset",
    "backend": "npm --prefix backend run dev",
    "mobile": "npm --prefix mobile start",
    "web": "npm --prefix mobile run web",
    "free-ports": "node scripts/free-ports.mjs",
    "predev": "node scripts/free-ports.mjs",
    "dev": "concurrently --names \"API,APP\" --prefix-colors \"magenta,cyan\" \"npm:backend\" \"npm:mobile\"",
    "preweb-app": "node scripts/free-ports.mjs",
    "web-app": "concurrently --names \"API,WEB\" --prefix-colors \"magenta,cyan\" \"npm:backend\" \"npm:web\"",
    "start": "npm run dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
