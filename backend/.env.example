# Copie ce fichier en .env et adapte les valeurs.

# Stockage : Supabase / PostgreSQL.
# URL du projet : Dashboard Supabase > Project Settings > API > Project URL.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Cle SERVICE_ROLE (cote serveur uniquement, contourne la RLS) : a garder SECRETE.
# Dashboard Supabase > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Port de l'API
PORT=4000

# Cle secrete pour signer les tokens de connexion (mets une longue valeur aleatoire).
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# Cle API GNews pour les actualites finance (gratuite sur https://gnews.io).
# Sans cle, l'onglet Marche affiche les opportunites mais pas les news.
GNEWS_API_TOKEN=
