# Copie ce fichier en .env et adapte les valeurs.

# MongoDB local (par defaut). Pour MongoDB Atlas, remplace par ton URI de connexion.
MONGODB_URI=mongodb://127.0.0.1:27017/finance_app

# Port de l'API
PORT=4000

# Cle secrete pour signer les tokens de connexion (mets une longue valeur aleatoire).
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# Cle API GNews pour les actualites finance (gratuite sur https://gnews.io).
# Sans cle, l'onglet Marche affiche les opportunites mais pas les news.
GNEWS_API_TOKEN=
